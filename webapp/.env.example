# Copy this file to .env.local and fill in the values from your Supabase project.
# Supabase dashboard -> Project Settings -> API

# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://fourthcanal.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# SECRET. Server + scripts only. Never share or commit this:
SUPABASE_SECRET_KEY=YOUR-SERVICE-ROLE-KEY

# Optional: where your downloaded course files live (for upload-files.mjs).
# COURSE_FILES_DIR=/Users/rickahn/Downloads/Case Western D1 Assets

# Optional: max upload size in MB (Supabase free tier bucket limit is 50 MB).
# UPLOAD_MAX_MB=50
# Use --compress with upload-files.mjs to shrink oversized PDFs via ghostscript.

# GroupMe OAuth (public client ID from dev.groupme.com)
# Callback URL must be: https://YOUR-DOMAIN/api/groupme/callback
# NEXT_PUBLIC_GROUPME_CLIENT_ID=your-client-id

# GroupMe bot for class maintenance announcements (from dev.groupme.com → Bots)
# GROUPME_BOT_ID=your-bot-id
# Optional display label so you know which group receives posts (e.g. "HEC Maintenance Test")
# GROUPME_BOT_LABEL=HEC Maintenance Test

# GroupMe bot for new course content announcements (falls back to GROUPME_BOT_ID)
# GROUPME_CONTENT_BOT_ID=your-content-bot-id
# GROUPME_CONTENT_BOT_LABEL=Fourth Canal

# Public site URL for links in GroupMe messages
NEXT_PUBLIC_SITE_URL=https://fourthcanal.com

# API key for bot/script uploads (Authorization: Bearer <key>)
# COURSE_BOT_API_KEY=generate-a-long-random-string
